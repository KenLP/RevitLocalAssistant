<UserControl x:Class="RevitAssistant.UI.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:RevitAssistant.UI"
             mc:Ignorable="d"
             d:DesignWidth="340" d:DesignHeight="560"
             d:DataContext="{d:DesignInstance Type=local:ChatViewModel, IsDesignTimeCreatable=True}"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Message bubble container -->
        <Style x:Key="BubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="MaxWidth" Value="280" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="Background" Value="#2563EB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Error">
                    <Setter Property="Background" Value="#B91C1C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="System">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="MaxWidth" Value="300" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Message body text -->
        <Style x:Key="BubbleText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Error">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="System">
                    <Setter Property="FontStyle" Value="Italic" />
                    <Setter Property="Opacity" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="8,6" Margin="2,2,2,4" CornerRadius="8"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🤖" FontSize="16" VerticalAlignment="Center" />
                <StackPanel Margin="8,0,0,0">
                    <TextBlock Text="Trợ lý Revit (Offline)" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                    <TextBlock Text="Tiếng Việt · English · Qwen2.5" FontSize="10" Opacity="0.7"
                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Auto" Padding="0,2">
            <Grid>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BubbleStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}" FontSize="10" Opacity="0.65"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                                    <TextBlock Text="{Binding Text}" Style="{StaticResource BubbleText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                           Opacity="0.55" VerticalAlignment="Center"
                           Text="Hỏi tôi về model: liệt kê phòng, kiểm tra cửa thoát hiểm, đổi tham số hàng loạt…"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </ScrollViewer>

        <!-- Busy indicator -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,2"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Đang xử lý…" FontSize="11" Opacity="0.7"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        </StackPanel>

        <!-- Pending-change confirmation card -->
        <Border Grid.Row="3" Margin="2,4,2,0" Padding="10,8" CornerRadius="8"
                BorderThickness="1" BorderBrush="#D97706" Background="#FEF3C7"
                Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding PendingPreview.Title}" FontWeight="SemiBold"
                           Foreground="#92400E" />
                <TextBlock Text="{Binding PendingPreview.Summary}" TextWrapping="Wrap"
                           Margin="0,2,0,6" Foreground="#92400E" />

                <Border Background="#FFFBEB" CornerRadius="6" Padding="6"
                        MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PendingPreview.Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Element}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Margin="0,0,8,0" Foreground="#78350F" />
                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                   FontSize="11" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#78350F" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFailure}" Value="True">
                                                            <Setter Property="Foreground" Value="#B91C1C" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Hủy" Command="{Binding CancelCommand}"
                            MinWidth="64" Padding="8,4" Margin="0,0,6,0" />
                    <Button Content="Xác nhận ghi" Command="{Binding ConfirmCommand}"
                            MinWidth="100" Padding="8,4" FontWeight="SemiBold"
                            Background="#16A34A" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Input -->
        <Border Grid.Row="4" Margin="2,4,2,2" Padding="4" CornerRadius="8"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="28" MaxHeight="100"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Center"
                         BorderThickness="0" Background="Transparent"
                         PreviewKeyDown="InputBox_PreviewKeyDown" />
                <Button Grid.Column="1" Content="Gửi" Command="{Binding SendCommand}"
                        MinWidth="56" Margin="4,0,0,0" Padding="8,4" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
