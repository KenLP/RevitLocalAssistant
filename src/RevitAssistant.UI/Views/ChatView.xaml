<UserControl x:Class="RevitAssistant.UI.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:RevitAssistant.UI"
             mc:Ignorable="d"
             d:DesignWidth="340" d:DesignHeight="560"
             d:DataContext="{d:DesignInstance Type=local:ChatViewModel, IsDesignTimeCreatable=True}"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:TableToGridConverter x:Key="TableToGrid" />

        <!-- Message bubble container -->
        <Style x:Key="BubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="MaxWidth" Value="280" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Background"
                    Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="Background" Value="#2563EB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Error">
                    <Setter Property="Background" Value="#B91C1C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="System">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="MaxWidth" Value="300" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsTable}" Value="True">
                    <Setter Property="MaxWidth" Value="380" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Message body text -->
        <Style x:Key="BubbleText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Error">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="System">
                    <Setter Property="FontStyle" Value="Italic" />
                    <Setter Property="Opacity" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Selectable message body: a read-only TextBox styled to look like text,
             so users can select words and Ctrl+C / right-click → Copy. -->
        <Style x:Key="BubbleTextBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Cursor" Value="IBeam" />
            <Setter Property="Foreground"
                    Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Error">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="System">
                    <Setter Property="FontStyle" Value="Italic" />
                    <Setter Property="Opacity" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="8,6" Margin="2,2,2,4" CornerRadius="8"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🤖" FontSize="16" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Trợ lý Revit AI" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                    <TextBlock Text="Tiếng Việt · English · Ollama · Qwen2.5" FontSize="10" Opacity="0.7"
                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                               Text="{Binding ContextUsagePercent, StringFormat='Ngữ cảnh {0}%'}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                                <Setter Property="Opacity" Value="0.6" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ContextUsagePercent}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ContextWarning}" Value="True">
                                        <Setter Property="Foreground" Value="#D97706" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="ToolTip"
                                                Value="Ngữ cảnh sắp đầy — hội thoại cũ đang được rút gọn. Nên bấm 🗑 Xóa để bắt đầu phiên mới." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="⚠" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"
                               Foreground="#D97706"
                               Visibility="{Binding ContextWarning, Converter={StaticResource BoolToVis}}" />
                    <Button Content="🗑 Xóa" Command="{Binding ResetCommand}" Padding="8,3" FontSize="11"
                            ToolTip="Xóa hội thoại, bắt đầu phiên mới" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Auto" Padding="0,2">
            <Grid>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BubbleStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}" FontSize="10" Opacity="0.65"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />

                                    <!-- TABLE bubble -->
                                    <StackPanel Visibility="{Binding IsTable, Converter={StaticResource BoolToVis}}">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto" MaxHeight="320">
                                            <ContentControl Content="{Binding Table, Converter={StaticResource TableToGrid}}" />
                                        </ScrollViewer>
                                        <TextBlock Text="{Binding Text}" FontSize="10" Opacity="0.6" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="📋 Copy bảng" Command="{Binding CopyTableCommand}"
                                                    Padding="6,2" FontSize="11"
                                                    ToolTip="Sao chép bảng (dán được vào Excel)" />
                                            <Button Content="📥 Xuất CSV" Command="{Binding ExportCsvCommand}"
                                                    Margin="6,0,0,0" Padding="6,2" FontSize="11"
                                                    ToolTip="Lưu bảng ra file CSV (UTF-8, mở được Excel)" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- TEXT bubble -->
                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                             Style="{StaticResource BubbleTextBox}"
                                             Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}" />

                                    <!-- 👍 / 👎 feedback (assistant only) -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0"
                                                Visibility="{Binding CanRate, Converter={StaticResource BoolToVis}}">
                                        <Button Content="👍" Command="{Binding ThumbUpCommand}"
                                                ToolTip="Phản hồi tốt" Padding="4,0" FontSize="12"
                                                BorderThickness="0" Background="Transparent" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0.45" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Feedback}" Value="Up">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="👎" Command="{Binding ThumbDownCommand}"
                                                ToolTip="Phản hồi chưa đúng" Padding="4,0" FontSize="12"
                                                BorderThickness="0" Background="Transparent" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0.45" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Feedback}" Value="Down">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                    <!-- reason box on 👎 -->
                                    <StackPanel Margin="0,4,0,0"
                                                Visibility="{Binding ShowReasonBox, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Điều gì chưa chính xác? (tuỳ chọn)" FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                                        <TextBox Text="{Binding ReasonText, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"
                                                 Margin="0,2,0,0" />
                                        <Button Content="Gửi góp ý" Command="{Binding SubmitReasonCommand}"
                                                HorizontalAlignment="Left" Margin="0,4,0,0" Padding="8,2" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                           Opacity="0.55" VerticalAlignment="Center"
                           Text="Hỏi tôi về model: liệt kê phòng, kiểm tra cửa thoát hiểm, đổi tham số hàng loạt…"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </ScrollViewer>

        <!-- Busy indicator -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,2"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Đang xử lý…" FontSize="11" Opacity="0.7"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        </StackPanel>

        <!-- Pending-change confirmation card -->
        <Border Grid.Row="3" Margin="2,4,2,0" Padding="10,8" CornerRadius="8"
                BorderThickness="1" BorderBrush="#D97706" Background="#FEF3C7"
                Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding PendingPreview.Title}" FontWeight="SemiBold"
                           Foreground="#92400E" />
                <TextBlock Text="{Binding PendingPreview.Summary}" TextWrapping="Wrap"
                           Margin="0,2,0,6" Foreground="#92400E" />

                <Border Background="#FFFBEB" CornerRadius="6" Padding="6"
                        MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PendingPreview.Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Element}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Margin="0,0,8,0" Foreground="#78350F" />
                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                   FontSize="11" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#78350F" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFailure}" Value="True">
                                                            <Setter Property="Foreground" Value="#B91C1C" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Hủy" Command="{Binding CancelCommand}"
                            MinWidth="64" Padding="8,4" Margin="0,0,6,0" />
                    <Button Content="Xác nhận ghi" Command="{Binding ConfirmCommand}"
                            MinWidth="100" Padding="8,4" FontWeight="SemiBold"
                            Background="#16A34A" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Undo last edit (available after a confirmed update_where) -->
        <Border Grid.Row="4" Margin="2,2,2,0" Padding="6,5" CornerRadius="6"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Visibility="{Binding HasUndo, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Vừa ghi thay đổi." VerticalAlignment="Center" FontSize="11" Opacity="0.75"
                           Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                <Button Content="⏪ Hoàn tác" Command="{Binding UndoCommand}"
                        Margin="8,0,0,0" Padding="8,3" FontSize="11"
                        ToolTip="Khôi phục giá trị trước khi ghi (undo lần cuối)" />
            </StackPanel>
        </Border>

        <!-- Input -->
        <Border Grid.Row="5" Margin="2,4,2,2" Padding="4" CornerRadius="8"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📎" Command="{Binding ImportFileCommand}"
                        Padding="6,4" Margin="0,0,4,0" FontSize="14"
                        BorderThickness="0" Background="Transparent" Cursor="Hand"
                        ToolTip="Nhập dữ liệu từ file Excel / CSV" />
                <TextBox Grid.Column="1" x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="28" MaxHeight="100"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Center"
                         BorderThickness="0" Background="Transparent"
                         PreviewKeyDown="InputBox_PreviewKeyDown" />
                <Button Grid.Column="2" Content="Gửi" Command="{Binding SendCommand}"
                        MinWidth="56" Margin="4,0,0,0" Padding="8,4" />
            </Grid>
        </Border>

        <!-- Disclaimer -->
        <TextBlock Grid.Row="6" Margin="6,4,6,2" TextAlignment="Center" TextWrapping="Wrap"
                   FontSize="10" Opacity="0.55"
                   Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                   Text="Câu trả lời do AI tạo có thể thiếu sót hoặc chưa chính xác. Hãy kiểm tra kết quả trước khi sử dụng." />
    </Grid>
</UserControl>
