<Solution>
  <!--
    extern/RevitMCPCore/src/RevitMCP.Core is deliberately NOT in the solution:
    its sources are compiled into RevitAssistant.Core (see that csproj). Building
    it here would produce a RevitMCP.Core.dll that must never ship from this repo.
  -->
  <Folder Name="/src/">
    <Project Path="src/RevitAssistant.Addin/RevitAssistant.Addin.csproj" />
    <Project Path="src/RevitAssistant.Compliance/RevitAssistant.Compliance.csproj" />
    <Project Path="src/RevitAssistant.Core/RevitAssistant.Core.csproj" />
    <Project Path="src/RevitAssistant.Llm/RevitAssistant.Llm.csproj" />
    <Project Path="src/RevitAssistant.Schema/RevitAssistant.Schema.csproj" />
    <Project Path="src/RevitAssistant.UI/RevitAssistant.UI.csproj" />
  </Folder>
  <Folder Name="/tests/">
    <Project Path="tests/RevitAssistant.Compliance.Tests/RevitAssistant.Compliance.Tests.csproj" />
    <Project Path="tests/RevitAssistant.Llm.Tests/RevitAssistant.Llm.Tests.csproj" />
    <Project Path="tests/RevitAssistant.UI.Tests/RevitAssistant.UI.Tests.csproj" />
  </Folder>
</Solution>
